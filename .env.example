# VIRASAT Environment Configuration
# Copy this file to .env and fill in your values.

FLASK_ENV=development
FLASK_APP=app.py

# A strong, random secret key (generate one with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-this-to-a-strong-random-secret-key

# For production, switch to PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/virasat_db
